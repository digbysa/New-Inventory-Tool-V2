<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Inventory Tool"
        Width="1366"
        Height="768"
        MinWidth="1200"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#DDE3E8"
        FontFamily="Segoe UI"
        FontSize="14">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderDarkBrush" Color="#333333"/>
        <SolidColorBrush x:Key="ToolbarDarkBrush" Color="#2F2F2F"/>
        <SolidColorBrush x:Key="WindowSurfaceBrush" Color="#F3F5F7"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D1D8E0"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="SectionTextBrush" Color="#475569"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#0EA5E9"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="DarkButtonBrush" Color="#1F2A44"/>
        <SolidColorBrush x:Key="DarkButtonHoverBrush" Color="#22304D"/>
        <SolidColorBrush x:Key="LightButtonBrush" Color="#EEF2F7"/>
        <SolidColorBrush x:Key="LightButtonHoverBrush" Color="#E4EAF2"/>
        <SolidColorBrush x:Key="SuccessButtonBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessButtonHoverBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="GoodBadgeBrush" Color="#DDF7E5"/>
        <SolidColorBrush x:Key="GoodBadgeTextBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="BlueBadgeBrush" Color="#DCEEFF"/>
        <SolidColorBrush x:Key="BlueBadgeTextBrush" Color="#0F5EA8"/>
        <SolidColorBrush x:Key="AmberBadgeBrush" Color="#FEE7C3"/>
        <SolidColorBrush x:Key="AmberBadgeTextBrush" Color="#B45309"/>
        <SolidColorBrush x:Key="RedBadgeBrush" Color="#FCE3E5"/>
        <SolidColorBrush x:Key="RedBadgeTextBrush" Color="#BE123C"/>
        <SolidColorBrush x:Key="LocationFillBrush" Color="#CCF2D3"/>
        <SolidColorBrush x:Key="LocationBorderBrush" Color="#7CE0A6"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#24FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource DarkButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkButtonBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkButtonHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource DarkButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Background" Value="{StaticResource LightButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#D8E0E9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SuccessButtonBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SuccessButtonHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SuccessButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValueBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style x:Key="LocationValueBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ValueBoxStyle}">
            <Setter Property="Background" Value="{StaticResource LocationFillBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LocationBorderBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="7,3"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SectionTextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6E8AA8"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompactDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E6EAEE"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFCFF"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="ColumnHeaderHeight" Value="28"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E6EAEE"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E6EAEE"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>



        <Style x:Key="LegacyNearbyDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource CompactDataGridStyle}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E6EAEE"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFCFF"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="ColumnHeaderHeight" Value="23"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E6EAEE"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E6EAEE"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible"/>
        </Style>

        <Style x:Key="NearbyButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E6E6E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NearbyShowAllButtonStyle" TargetType="Button" BasedOn="{StaticResource NearbyButtonStyle}">
            <Setter Property="Background" Value="#F5F6F8"/>
            <Setter Property="BorderBrush" Value="#D5DBE3"/>
            <Setter Property="Width" Value="66"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>

        <Style x:Key="NearbySaveButtonStyle" TargetType="Button" BasedOn="{StaticResource NearbyButtonStyle}">
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="118"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>

        <Style x:Key="NearbyCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0,0,0"/>
        </Style>

        <Style x:Key="NearbyCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="LineHeight" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="NearbyHostCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource NearbyCellTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding PingStatus}" Value="Success">
                    <Setter Property="Foreground" Value="ForestGreen"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PingStatus}" Value="Fail">
                    <Setter Property="Foreground" Value="Crimson"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E6EAEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#E6EAEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Border Background="#CDD4DC" Height="1" VerticalAlignment="Bottom"/>
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Grid>
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="0,0,8,10"/>
            <Setter Property="Margin" Value="0,0,26,0"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="0,0,2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckRowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D9E1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="RoundingCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header row intentionally collapsed so the default Windows title bar is the only title area -->
        <Border Grid.Row="0" Height="0" Background="{StaticResource HeaderDarkBrush}"/>

        <!-- Search / action bar -->
        <Border Grid.Row="1" Background="{StaticResource ToolbarDarkBrush}" BorderBrush="#404040" BorderThickness="0,1,0,1">
            <Grid Margin="10,6,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#5F7691"
                        BorderThickness="1"
                        Background="#2F2F2F"
                        Height="28"
                        CornerRadius="5"
                        SnapsToDevicePixels="True"
                        Margin="0,0,18,2">
                    <TextBox x:Name="SearchTextBox"
                             Text=""
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             CaretBrush="White"
                             Padding="10,3,10,4"
                             VerticalContentAlignment="Center"/>
                </Border>

                <Button x:Name="QueryButton" Grid.Column="1" Content="Query" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"/>
                <Button x:Name="PingButton" Grid.Column="2" Content="Ping" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"/>
                <Button x:Name="LiveDetailsButton" Grid.Column="3" Content="Live Details" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"/>
                <Button x:Name="MonitorLabelButton" Grid.Column="4" Content="Monitor Label" Style="{StaticResource ToolbarButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <TabControl x:Name="MainTabControl"
                    Grid.Row="2"
                    Background="{StaticResource WindowSurfaceBrush}"
                    Margin="18,12,18,10">
                <TabItem x:Name="SystemTab"><TabItem.Header><TextBlock Text="System" Margin="0,0,8,0"/></TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <Grid Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Status row -->
                        <Border Grid.Row="0" Background="Transparent" BorderBrush="#E3E8EF" BorderThickness="0,0,0,1" Padding="0,4,12,12" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="DeviceStatusIcon" Width="15" Height="15" Background="{StaticResource BlueBrush}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="SelectedDeviceText" Text="AO400568" Foreground="#0F5EA8" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="DeviceOnlineDot" Width="5" Height="5" Fill="#16A34A" Margin="12,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DeviceOnlineText" Text="Online" Foreground="#16A34A" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DeviceResponseTimeText" Text="(37 ms)" Foreground="#94A3B8" Margin="4,0,0,0" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DeviceIpText" Text="IP: Unknown" Foreground="#64748B" Margin="12,0,0,0" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock x:Name="DeviceSubnetText" Text="Subnet: Unknown" Foreground="#64748B" Margin="12,0,0,0" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>

                                <TextBlock x:Name="LastQueryBadgeText"
                                           Grid.Column="1"
                                           Text="Queried 13:52"
                                           Foreground="#64748B"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,34,0"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="400"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2.1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Device Summary -->
                            <Border Grid.Row="0" Grid.Column="0" MinHeight="350" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="DEVICE SUMMARY" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Core identity, lifecycle, and rounding state" Style="{StaticResource SectionSubtitleStyle}"/>
                                            </StackPanel>
                                            <Button x:Name="FixNameButton" Grid.Column="1" Content="Fix Name" Visibility="Collapsed" Style="{StaticResource SecondaryButtonStyle}" FontSize="13" Padding="10,5" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="12,10,12,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Detected Type" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetectedTypeDisplay" Text="Tangent" Foreground="#1F2937" FontWeight="SemiBold" FontSize="14" Margin="10,0,0,8"/>
                                        <TextBox x:Name="DetectedTypeTextBox" Visibility="Collapsed" Text="Tangent"/>
                                        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HostNameDisplay" Text="AO400568" Foreground="#1F2937" FontWeight="SemiBold" FontSize="14" Margin="10,10,0,8" VerticalAlignment="Center"/>
                                        <TextBox x:Name="HostNameTextBox" Visibility="Collapsed" Text="AO400568"/>
                                        <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Asset Tag" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AssetTagDisplay" Text="HSS-8093577" Foreground="#1F2937" FontWeight="SemiBold" FontSize="14" Margin="10,10,0,8"/>
                                        <TextBox x:Name="AssetTagTextBox" Visibility="Collapsed" Text="HSS-8093577"/>
                                        <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

