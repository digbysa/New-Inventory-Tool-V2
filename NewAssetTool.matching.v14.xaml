                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Host Name" Width="115" Binding="{Binding HostName}" ElementStyle="{StaticResource NearbyHostCellTextStyle}"/>
                                <DataGridTextColumn Header="IP Address" Width="110" Binding="{Binding IPAddress}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Subnet" Width="80" Binding="{Binding Subnet}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Asset Tag" Width="100" Binding="{Binding AssetTag}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Location" Width="500" Binding="{Binding Location}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Building" Width="145" Binding="{Binding Building}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Floor" Width="65" Binding="{Binding Floor}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Room" Width="145" Binding="{Binding Room}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Department" Width="85" Binding="{Binding Department}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Maintenance Type" Width="60" Binding="{Binding MaintenanceType}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
                                <DataGridTextColumn Header="Last Rounded" Width="65" Binding="{Binding LastRounded}" ElementStyle="{StaticResource NearbyCellTextStyle}"/>
