<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Inventory Tool"
        Width="1366"
        Height="768"
        MinWidth="1200"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#DDE3E8"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderDarkBrush" Color="#333333"/>
        <SolidColorBrush x:Key="ToolbarDarkBrush" Color="#2F2F2F"/>
        <SolidColorBrush x:Key="WindowSurfaceBrush" Color="#F3F5F7"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D1D8E0"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="SectionTextBrush" Color="#475569"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#0EA5E9"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="DarkButtonBrush" Color="#1F2A44"/>
        <SolidColorBrush x:Key="DarkButtonHoverBrush" Color="#22304D"/>
        <SolidColorBrush x:Key="LightButtonBrush" Color="#EEF2F7"/>
        <SolidColorBrush x:Key="LightButtonHoverBrush" Color="#E4EAF2"/>
        <SolidColorBrush x:Key="SuccessButtonBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessButtonHoverBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="GoodBadgeBrush" Color="#DDF7E5"/>
        <SolidColorBrush x:Key="GoodBadgeTextBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="BlueBadgeBrush" Color="#DCEEFF"/>
        <SolidColorBrush x:Key="BlueBadgeTextBrush" Color="#0F5EA8"/>
        <SolidColorBrush x:Key="AmberBadgeBrush" Color="#FEE7C3"/>
        <SolidColorBrush x:Key="AmberBadgeTextBrush" Color="#B45309"/>
        <SolidColorBrush x:Key="RedBadgeBrush" Color="#FCE3E5"/>
        <SolidColorBrush x:Key="RedBadgeTextBrush" Color="#BE123C"/>
        <SolidColorBrush x:Key="LocationFillBrush" Color="#CCF2D3"/>
        <SolidColorBrush x:Key="LocationBorderBrush" Color="#7CE0A6"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#24FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource DarkButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkButtonBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource DarkButtonHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource DarkButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Background" Value="{StaticResource LightButtonBrush}"/>
            <Setter Property="BorderBrush" Value="#D8E0E9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource LightButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SuccessButtonBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SuccessButtonHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SuccessButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValueBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style x:Key="LocationValueBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ValueBoxStyle}">
            <Setter Property="Background" Value="{StaticResource LocationFillBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LocationBorderBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="BadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="7,3"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SectionTextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6E8AA8"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompactDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D9E1EA"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FBFCFD"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="ColumnHeaderHeight" Value="28"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E4E9F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E4E9F0"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E4E9F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#E4E9F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Border Background="#CDD4DC" Height="1" VerticalAlignment="Bottom"/>
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Grid>
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="0,0,8,10"/>
            <Setter Property="Margin" Value="0,0,26,0"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="0,0,2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CheckRowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D9E1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="RoundingCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header row intentionally collapsed so the default Windows title bar is the only title area -->
        <Border Grid.Row="0" Height="0" Background="{StaticResource HeaderDarkBrush}"/>

        <!-- Search / action bar -->
        <Border Grid.Row="1" Background="{StaticResource ToolbarDarkBrush}" BorderBrush="#404040" BorderThickness="0,1,0,1">
            <Grid Margin="10,6,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#5F7691"
                        BorderThickness="1"
                        Background="#2F2F2F"
                        Height="28"
                        CornerRadius="5"
                        SnapsToDevicePixels="True"
                        Margin="0,0,18,2">
                    <TextBox x:Name="SearchTextBox"
                             Text="AO400568"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="10,3,10,4"
                             VerticalContentAlignment="Center"/>
                </Border>

                <Button x:Name="QueryButton" Grid.Column="1" Content="Query" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"/>
                <Button x:Name="PingButton" Grid.Column="2" Content="Ping" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"/>
                <Button x:Name="LiveDetailsButton" Grid.Column="3" Content="Live Details" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,12,0"/>
                <Button x:Name="MonitorLabelButton" Grid.Column="4" Content="Monitor Label" Style="{StaticResource ToolbarButtonStyle}"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="2"
                      Background="{StaticResource WindowSurfaceBrush}"
                      Margin="18,12,18,10"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <TabControl x:Name="MainTabControl">
                <TabItem x:Name="SystemTab"><TabItem.Header><TextBlock Text="System" Margin="0,0,8,0"/></TabItem.Header>
                    <Grid Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Status row -->
                        <Border Grid.Row="0" Background="Transparent" BorderBrush="#E3E8EF" BorderThickness="0,0,0,1" Padding="0,4,12,12" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="15" Height="15" Background="{StaticResource BlueBrush}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="SelectedDeviceText" Text="AO400568" Foreground="#0F5EA8" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                    <Ellipse Width="5" Height="5" Fill="#16A34A" Margin="12,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DeviceOnlineText" Text="Online" Foreground="#16A34A" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text=" (37 ms)" Foreground="#94A3B8" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                                    <Border Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource GoodBadgeBrush}" Margin="12,0,6,0">
                                        <TextBlock Text="WMI" Foreground="{StaticResource GoodBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                                    </Border>
                                    <Border Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource GoodBadgeBrush}" Margin="0,0,6,0">
                                        <TextBlock Text="PSRemoting" Foreground="{StaticResource GoodBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                                    </Border>
                                    <Border Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource GoodBadgeBrush}">
                                        <TextBlock Text="SMB" Foreground="{StaticResource GoodBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="LastQueryBadgeText"
                                           Grid.Column="1"
                                           Text="Queried 13:52"
                                           Foreground="#64748B"
                                           FontWeight="SemiBold"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="0,0,34,0"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="382"/>
                                <RowDefinition Height="350"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2.1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Device Summary -->
                            <Border Grid.Row="0" Grid.Column="0" Height="350" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="DEVICE SUMMARY" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Core identity, lifecycle, and rounding state" Style="{StaticResource SectionSubtitleStyle}"/>
                                            </StackPanel>
                                            <Button x:Name="FixNameButton" Grid.Column="1" Content="Fix Name" Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="10,5" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="12,10,12,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Detected Type" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetectedTypeDisplay" Text="Tangent" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,0,0,8"/>
                                        <TextBox x:Name="DetectedTypeTextBox" Visibility="Collapsed" Text="Tangent"/>
                                        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HostNameDisplay" Text="AO400568" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,10,0,8" VerticalAlignment="Center"/>
                                        <TextBox x:Name="HostNameTextBox" Visibility="Collapsed" Text="AO400568"/>
                                        <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Asset Tag" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AssetTagDisplay" Text="HSS-8093577" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,10,0,8"/>
                                        <TextBox x:Name="AssetTagTextBox" Visibility="Collapsed" Text="HSS-8093577"/>
                                        <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Serial" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SerialDisplay" Text="C24102M031" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,10,0,8"/>
                                        <TextBox x:Name="SerialNumberTextBox" Visibility="Collapsed" Text="C24102M031"/>
                                        <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Parent" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ParentDisplay" Text="(n/a)" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,10,0,8"/>
                                        <TextBox x:Name="ParentTextBox" Visibility="Collapsed" Text="(n/a)"/>
                                        <Border Grid.Row="4" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="PO / RITM" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="RitmDisplay" Text="TRP - 26 May 2025" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,10,0,8"/>
                                        <TextBox x:Name="RitmTextBox" Visibility="Collapsed" Text="TRP - 26 May 2025"/>
                                        <Border Grid.Row="5" Grid.ColumnSpan="2" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Retire Date" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,8"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="RetireDisplay" Text="31 May 2028" Foreground="#1F2937" FontWeight="SemiBold" FontSize="12" Margin="10,10,0,8"/>
                                        <TextBox x:Name="RetireDateTextBox" Visibility="Collapsed" Text="31 May 2028"/>

                                        <Border Grid.Row="7" Grid.ColumnSpan="2" Background="#FDF0F1" BorderBrush="#F5C2C7" BorderThickness="1" CornerRadius="3" Margin="0,4,0,0" Padding="10,2,10,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="LAST ROUNDED" Foreground="#BE123C" FontWeight="SemiBold" FontSize="10"/>
                                                    <TextBlock x:Name="LastRoundedText" Text="12 March 2026 - 39 days ago" Foreground="#BE123C" FontWeight="SemiBold" FontSize="10" Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#FBE4E7" CornerRadius="3" Padding="8,2" VerticalAlignment="Center">
                                                    <TextBlock Text="Attention needed" Foreground="#BE123C" FontWeight="SemiBold" FontSize="10"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Associated Devices -->
                            <Border Grid.Row="0" Grid.Column="1" Height="350" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="ASSOCIATED DEVICES" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Parent and related equipment" Style="{StaticResource SectionSubtitleStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="AddPeripheralButton" Content="Add Peripheral" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                                                <Button x:Name="RemovePeripheralButton" Content="Remove Peripheral" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                                <Button x:Name="ValidateAssociatedButton" Content="Validate" Style="{StaticResource SuccessButtonStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Margin="12,10,12,12"
                                            BorderBrush="#D9E1EA"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Background="White"
                                            VerticalAlignment="Top">
                                        <DataGrid x:Name="AssociatedDevicesDataGrid"
                                                  Margin="0"
                                                  Style="{StaticResource CompactDataGridStyle}"
                                                  CanUserSortColumns="False"
                                                  VerticalAlignment="Top"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  GridLinesVisibility="None"
                                                  AlternationCount="2"
                                                  RowBackground="#F5FAFF"
                                                  AlternatingRowBackground="White"
                                                  RowHeight="42"
                                                  ColumnHeaderHeight="40"
                                                  HeadersVisibility="Column"
                                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <DataGrid.Resources>
                                                <Style TargetType="{x:Type DataGridColumnHeader}">
                                                    <Setter Property="Background" Value="#F4F6F8"/>
                                                    <Setter Property="BorderBrush" Value="#D9E1EA"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="Foreground" Value="#7A8CA3"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                    <Setter Property="Padding" Value="12,6,12,6"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                                <Style TargetType="{x:Type DataGridCell}">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="12,7,12,7"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                </Style>
                                                <Style TargetType="{x:Type DataGridRow}">
                                                    <Setter Property="Background" Value="#F5FAFF"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ROLE" Width="90" Binding="{Binding Role}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                                <DataGridTextColumn Header="TYPE" Width="90" Binding="{Binding Type}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                                <DataGridTextColumn Header="NAME" Width="*" Binding="{Binding Name}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                                <DataGridTextColumn Header="ASSET TAG" Width="150" Binding="{Binding AssetTag}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                                <DataGridTextColumn Header="SERIAL" Width="145" Binding="{Binding Serial}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                                <DataGridTextColumn Header="RITM" Width="170" Binding="{Binding RITM}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                                <DataGridTextColumn Header="RETIRE" Width="130" Binding="{Binding Retire}"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Device Location -->
                            <Border Grid.Row="1" Grid.Column="0" Height="382" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="DEVICE LOCATION" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Validated site and room placement" Style="{StaticResource SectionSubtitleStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button x:Name="EditLocationButton" Content="Edit Location" Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button x:Name="CancelEditLocationButton" Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Visibility="Collapsed" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="12,12,12,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="City" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="CityTextBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource LocationValueBoxStyle}" Text="Duncan"/>
                                        <ComboBox x:Name="CityComboBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource EditorComboStyle}" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,0"/>
                                        <TextBox x:Name="LocationTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource LocationValueBoxStyle}" Text="VIHA-CDH-Cowichan District Hospital" Margin="0,10,0,0"/>
                                        <ComboBox x:Name="LocationComboBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource EditorComboStyle}" Visibility="Collapsed" Margin="0,10,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Building" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,0"/>
                                        <TextBox x:Name="BuildingTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource LocationValueBoxStyle}" Text="Main Building" Margin="0,10,0,0"/>
                                        <ComboBox x:Name="BuildingComboBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource EditorComboStyle}" Visibility="Collapsed" Margin="0,10,0,0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Floor" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,0"/>
                                        <TextBox x:Name="FloorTextBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource LocationValueBoxStyle}" Text="1" Margin="0,10,0,0"/>
                                        <ComboBox x:Name="FloorComboBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource EditorComboStyle}" Visibility="Collapsed" Margin="0,10,0,0"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Room" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,0"/>
                                        <TextBox x:Name="RoomTextBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource LocationValueBoxStyle}" Text="1068 (PACU)" Margin="0,10,0,0"/>
                                        <ComboBox x:Name="RoomComboBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource EditorComboStyle}" Visibility="Collapsed" Margin="0,10,0,0"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Department" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,0"/>
                                        <TextBox x:Name="DepartmentTextBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource LocationValueBoxStyle}" Text="Medical Device Reprocessing Department (MDRD)" Margin="0,10,0,0"/>
                                        <ComboBox x:Name="DepartmentComboBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource EditorComboStyle}" Visibility="Collapsed" Margin="0,10,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Device Rounding -->
                            <Border Grid.Row="1" Grid.Column="1" Height="382" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="DEVICE ROUNDING" Style="{StaticResource SectionTitleStyle}"/>
                                            <TextBlock Text="Operational checklist and event capture" Style="{StaticResource SectionSubtitleStyle}"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="12,12,12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="3" Background="#F8FAFC" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="MAINTENANCE TYPE" Foreground="#64748B" FontSize="10" FontWeight="SemiBold"/>
                                                <ComboBox x:Name="MaintenanceTypeComboBox" Style="{StaticResource EditorComboStyle}" Margin="0,6,0,0">
                                                    <ComboBoxItem Content="Mobile Cart" IsSelected="True"/>
                                                    <ComboBoxItem Content="General Rounding"/>
                                                    <ComboBoxItem Content="Computer"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="3" Background="#F8FAFC" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="CHECK STATUS" Foreground="#64748B" FontSize="10" FontWeight="SemiBold"/>
                                                <ComboBox x:Name="CheckStatusComboBox" Style="{StaticResource EditorComboStyle}" Margin="0,6,0,0">
                                                    <ComboBoxItem Content="Complete" IsSelected="True"/>
                                                    <ComboBoxItem Content="Incomplete"/>
                                                    <ComboBoxItem Content="Needs Follow-up"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="3" Background="#F8FAFC" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="ROUNDING TIME" Foreground="#64748B" FontSize="10" FontWeight="SemiBold"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="RoundingTimeTextBox" Grid.Column="0" Style="{StaticResource ValueBoxStyle}" FontSize="12" MinHeight="28" Height="28" Text="3" IsReadOnly="False"/>
                                                    <Grid Grid.Column="1" Margin="2,0,0,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Button x:Name="RoundingTimeUpButton" Grid.Row="0" Content="+" Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="10" Height="6" MinHeight="6"/>
                                                        <Button x:Name="RoundingTimeDownButton" Grid.Row="1" Content="-" Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="10" Height="6" MinHeight="6" Margin="0,2,0,0"/>
                                                    </Grid>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="12,0,12,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <Border Style="{StaticResource CheckRowBorderStyle}">
                                                <CheckBox x:Name="ValidateCableCheckBox" Style="{StaticResource RoundingCheckBoxStyle}" Content="Validate cable management"/>
                                            </Border>
                                            <Border Style="{StaticResource CheckRowBorderStyle}">
                                                <CheckBox x:Name="LabelMonitorCheckBox" Style="{StaticResource RoundingCheckBoxStyle}" Content="Ensure monitor appropriately labelled"/>
                                            </Border>
                                            <Border Style="{StaticResource CheckRowBorderStyle}">
                                                <CheckBox x:Name="ValidatePeripheralsCheckBox" Style="{StaticResource RoundingCheckBoxStyle}" Content="Validate peripherals are connected and working"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <Border Style="{StaticResource CheckRowBorderStyle}">
                                                <CheckBox x:Name="CablingNeededCheckBox" Style="{StaticResource RoundingCheckBoxStyle}" Content="Cabling needed"/>
                                            </Border>
                                            <Border Style="{StaticResource CheckRowBorderStyle}">
                                                <CheckBox x:Name="PhysicalCartCheckBox" Style="{StaticResource RoundingCheckBoxStyle}" Content="Check physical cart is working"/>
                                            </Border>
                                            <Border Style="{StaticResource CheckRowBorderStyle}">
                                                <CheckBox x:Name="AddDeviceToTrackerCheckBox" Style="{StaticResource RoundingCheckBoxStyle}" Content="Add device to device tracker"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="12,0,12,10" HorizontalAlignment="Left">
                                        <Button x:Name="CheckCompleteButton" Content="Check Complete" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                                        <Button x:Name="SaveEventButton" Content="Save Event" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,8,0"/>
                                        <Button x:Name="ManualRoundButton" Content="Manual Round" Style="{StaticResource PrimaryButtonStyle}"/>
                                    </StackPanel>

                                    <Border Grid.Row="4" Margin="12,0,12,12" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="3" Background="White">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="28"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" BorderBrush="#E4E9F0" BorderThickness="0,0,0,1" Background="#F8FAFC">
                                                <TextBlock Text="COMMENTS" Foreground="#64748B" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </Border>
                                            <TextBox x:Name="CommentsTextBox" Grid.Row="1" BorderThickness="0" Background="White" Padding="10" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Foreground="#94A3B8" Text="Add issues found, cart problems, labelling notes, cable concerns, or follow-up actions here..."/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="NearbyTab"><TabItem.Header><TextBlock Text="Nearby" Margin="0,0,8,0"/></TabItem.Header>
                    <Grid Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="NearbyScopeSummaryText" Text="Nearby scopes (Location): 1 - Showing 84" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBlock Text="Devices in the same nearby scope, styled to match the system page." Foreground="#6B7280" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="RebuildNearbyButton" Content="Rebuild Nearby" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                    <Button x:Name="PingAllButton" Content="Ping All" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                    <Button x:Name="ClearNearbyButton" Content="Clear List" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                    <Button x:Name="NearbyCollapseButton" Content="-" Style="{StaticResource SecondaryButtonStyle}" Width="28" Margin="0,0,8,0"/>
                                    <Button x:Name="NearbyExpandButton" Content="+" Style="{StaticResource SecondaryButtonStyle}" Width="28"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12,10" Margin="0,0,0,10">
                            <WrapPanel>
                                <CheckBox x:Name="ShowAllNearbyCheckBox" Content="Show All (84)" Margin="0,0,16,0"/>
                                <CheckBox x:Name="TodaysRoundedCheckBox" Content="Today's Rounded (9)" IsChecked="True" Margin="0,0,16,0"/>
                                <CheckBox x:Name="ExcludedCheckBox" Content="Excluded (7)" Margin="0,0,16,0"/>
                                <CheckBox x:Name="RecentlyRoundedCheckBox" Content="Recently Rounded (50)" Margin="0,0,16,0"/>
                                <CheckBox x:Name="CriticalClinicalCheckBox" Content="Critical Clinical (0)" IsChecked="True"/>
                            </WrapPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,10">
                            <DataGrid x:Name="NearbyDataGrid" Style="{StaticResource CompactDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="HOST NAME" Width="95" Binding="{Binding HostName}"/>
                                    <DataGridTextColumn Header="IP ADDRESS" Width="105" Binding="{Binding IPAddress}"/>
                                    <DataGridTextColumn Header="SUBNET" Width="70" Binding="{Binding Subnet}"/>
                                    <DataGridTextColumn Header="ASSET TAG" Width="105" Binding="{Binding AssetTag}"/>
                                    <DataGridTextColumn Header="LOCATION" Width="115" Binding="{Binding Location}"/>
                                    <DataGridTextColumn Header="BUILDING" Width="95" Binding="{Binding Building}"/>
                                    <DataGridTextColumn Header="FLOOR" Width="45" Binding="{Binding Floor}"/>
                                    <DataGridTextColumn Header="ROOM" Width="120" Binding="{Binding Room}"/>
                                    <DataGridTextColumn Header="DEPARTMENT" Width="115" Binding="{Binding Department}"/>
                                    <DataGridTextColumn Header="MAINTENANCE TYPE" Width="105" Binding="{Binding MaintenanceType}"/>
                                    <DataGridTextColumn Header="LAST ROUNDED" Width="105" Binding="{Binding LastRounded}"/>
                                    <DataGridTextColumn Header="DAYS AGO" Width="55" Binding="{Binding DaysAgo}"/>
                                    <DataGridTextColumn Header="STATUS" Width="*" Binding="{Binding Status}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bulk Save adds events with selected Status, 3 min each." Foreground="#6B7280" VerticalAlignment="Center"/>
                                <Button x:Name="NearbySaveButton" Grid.Column="1" Content="Save" Style="{StaticResource SuccessButtonStyle}" MinWidth="84"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#EEF2F5" BorderBrush="#CCD6E0" BorderThickness="0,1,0,0">
            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="DataPathText" Text="Data: C:\Users\da1701_sa\Desktop\New-Inventory-Tool\Data" Foreground="#64748B" FontSize="10" Margin="0,0,14,0"/>
                    <TextBlock x:Name="OutputPathText" Text="Output: C:\Users\da1701_sa\Desktop\New-Inventory-Tool\Output" Foreground="#64748B" FontSize="10"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="DaysPerWeekBadge" Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource BlueBadgeBrush}" Margin="0,0,6,0">
                        <TextBlock Text="Days/week 5" Foreground="{StaticResource BlueBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                    </Border>
                    <Border x:Name="TodayBadge" Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource AmberBadgeBrush}" Margin="0,0,6,0">
                        <TextBlock Text="Today 9 / 30" Foreground="{StaticResource AmberBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                    </Border>
                    <Border x:Name="ThisWeekBadge" Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource AmberBadgeBrush}" Margin="0,0,6,0">
                        <TextBlock Text="This week 9 / 150" Foreground="{StaticResource AmberBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                    </Border>
                    <Border x:Name="RemainingPerDayBadge" Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource GoodBadgeBrush}" Margin="0,0,6,0">
                        <TextBlock Text="Remaining per day 36" Foreground="{StaticResource GoodBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                    </Border>
                    <Border x:Name="StatusMessageBadge" Style="{StaticResource BadgeBorderStyle}" Background="{StaticResource RedBadgeBrush}">
                        <TextBlock Text="Found Computer / Computer" Foreground="{StaticResource RedBadgeTextBrush}" FontWeight="SemiBold" FontSize="10"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
