                                            <Setter Property="Foreground" Value="#000000"/>
                                            <Setter Property="BorderBrush" Value="#B7D7F3"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="{x:Type DataGridCell}">
                                    <Setter Property="Foreground" Value="#000000"/>
